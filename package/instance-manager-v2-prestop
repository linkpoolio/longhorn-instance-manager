#!/bin/bash

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S.%N') $*"
}

function cleanup_spdk_resources() {
    log "Caught termination signal. Cleaning up SPDK resources..."

    local v2_devices=($(get_v2_devices))
    for device in "${v2_devices[@]}"; do
        dmsetup remove "$device"
        log "Removed device-mapper device: $device"

        device_file="/host/dev/longhorn/$device"
        rm "$device_file"
        log "Removed device file: $device_file"
    done

    log "Sending SIGTERM to go-spdk-helper to stop spdk_tgt..."
    go-spdk-helper kill-instance --sig-name SIGTERM
    if [[ $? -ne 0 ]]; then
        log "Failed to send SIGTERM to go-spdk-helper"
    else
        log "Successfully sent SIGTERM to go-spdk-helper"
    fi

    # Wait for spdk_tgt to fully exit before returning. Without this, kubelet's
    # terminationGracePeriodSeconds clock can expire while SPDK is still
    # flushing its blobstore, forcing SIGKILL mid-flush. That leaves the
    # on-disk dirty bit set and the next boot runs a full blobstore recovery
    # (15-30 min on a multi-TiB disk). Cleanly exiting here skips recovery
    # entirely. Cap at 270s: grace period is 300s, leaving 30s headroom.
    local deadline=$(( $(date +%s) + 270 ))
    while pidof spdk_tgt > /dev/null 2>&1; do
        if [[ $(date +%s) -ge ${deadline} ]]; then
            log "Timed out waiting for spdk_tgt to exit; blobstore may recover on next boot"
            return
        fi
        sleep 1
    done
    log "spdk_tgt exited cleanly after SIGTERM"
}

function get_v2_devices() {
    local dm_devices
    dm_devices=$(dmsetup ls 2>/dev/null | awk '{print $1}')
    local v2_devices=()

    if [[ ! -d /host/dev/longhorn/ ]]; then
        echo "${v2_devices[@]}"
        return
    fi

    local device_files
    device_files=$(ls /host/dev/longhorn/)

    for dm_device in $dm_devices; do
        for device_file in $device_files; do
            if [[ "$dm_device" == "$device_file" ]]; then
                v2_devices+=("$dm_device")
                break
            fi
        done
    done

    echo "${v2_devices[@]}"
}

cleanup_spdk_resources
